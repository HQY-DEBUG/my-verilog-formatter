{
    "name": "my-verilog-formatter",
    "displayName": "Verilog Formatter",
    "description": "Verilog / SystemVerilog 代码格式化、文件树、例化、语法高亮、跳转等",
    "version": "0.2.0",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Formatters",
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:verilog",
        "onLanguage:systemverilog",
        "onLanguage:ucf",
        "onLanguage:xdc",
        "onLanguage:vhdl",
        "onLanguage:tcl",
        "onLanguage:modelsim-do",
        "onLanguage:gowin-cst",
        "onView:verilogFileTree",
        "workspaceContains:**/*.v",
        "workspaceContains:**/*.sv"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "verilog",
                "aliases": [
                    "Verilog",
                    "verilog"
                ],
                "extensions": [
                    ".v",
                    ".vh"
                ],
                "configuration": "./language-configuration-verilog.json"
            },
            {
                "id": "systemverilog",
                "aliases": [
                    "SystemVerilog",
                    "systemverilog"
                ],
                "extensions": [
                    ".sv",
                    ".svh"
                ],
                "configuration": "./language-configuration-verilog.json"
            },
            {
                "id": "ucf",
                "aliases": [
                    "UCF Constraint",
                    "ucf"
                ],
                "extensions": [
                    ".ucf"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "xdc",
                "aliases": [
                    "XDC Constraint",
                    "xdc"
                ],
                "extensions": [
                    ".xdc"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "vhdl",
                "aliases": [
                    "VHDL",
                    "vhdl"
                ],
                "extensions": [
                    ".vhd",
                    ".vhdl"
                ],
                "configuration": "./language-configuration-vhdl.json"
            },
            {
                "id": "tcl",
                "aliases": [
                    "Tcl",
                    "tcl"
                ],
                "extensions": [
                    ".tcl"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "modelsim-do",
                "aliases": [
                    "ModelSim DO",
                    "do"
                ],
                "extensions": [
                    ".do"
                ],
                "configuration": "./language-configuration.json"
            },
            {
                "id": "gowin-cst",
                "aliases": [
                    "GoWin CST",
                    "cst"
                ],
                "extensions": [
                    ".cst"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "snippets": [
            {
                "language": "verilog",
                "path": "./snippets/verilog.code-snippets"
            },
            {
                "language": "systemverilog",
                "path": "./snippets/verilog.code-snippets"
            }
        ],
        "grammars": [
            {
                "language": "verilog",
                "scopeName": "source.verilog",
                "path": "./syntaxes/verilog.tmLanguage.json"
            },
            {
                "language": "systemverilog",
                "scopeName": "source.systemverilog",
                "path": "./syntaxes/systemverilog.tmLanguage.json",
                "embeddedLanguages": {
                    "source.verilog": "verilog"
                }
            },
            {
                "language": "ucf",
                "scopeName": "source.ucf",
                "path": "./syntaxes/ucf.tmLanguage.json"
            },
            {
                "language": "xdc",
                "scopeName": "source.xdc",
                "path": "./syntaxes/xdc.tmLanguage.json"
            },
            {
                "language": "vhdl",
                "scopeName": "source.vhdl",
                "path": "./syntaxes/vhdl.tmLanguage.json"
            },
            {
                "language": "tcl",
                "scopeName": "source.tcl",
                "path": "./syntaxes/tcl.tmLanguage.json"
            },
            {
                "language": "modelsim-do",
                "scopeName": "source.do",
                "path": "./syntaxes/do.tmLanguage.json"
            },
            {
                "language": "gowin-cst",
                "scopeName": "source.cst",
                "path": "./syntaxes/cst.tmLanguage.json"
            }
        ],
        "views": {
            "explorer": [
                {
                    "id": "verilogFileTree",
                    "name": "Verilog 文件树",
                    "when": "workbenchState != empty"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "verilogFormatter.refreshFileTree",
                    "when": "view == verilogFileTree",
                    "group": "navigation"
                },
                {
                    "command": "verilogFormatter.setTopModule",
                    "when": "view == verilogFileTree",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "verilogFormatter.instantiate",
                    "when": "editorLangId =~ /verilog|systemverilog/",
                    "group": "verilog@1"
                },
                {
                    "command": "verilogFormatter.generateTb",
                    "when": "editorLangId =~ /verilog|systemverilog/",
                    "group": "verilog@2"
                },
                {
                    "command": "verilogFormatter.ucfToXdc",
                    "when": "editorLangId == ucf",
                    "group": "verilog@3"
                }
            ]
        },
        "commands": [
            {
                "command": "verilogFormatter.instantiate",
                "title": "Verilog: 一键例化（复制到剪贴板）"
            },
            {
                "command": "verilogFormatter.generateTb",
                "title": "Verilog: 一键生成 Testbench"
            },
            {
                "command": "verilogFormatter.refreshFileTree",
                "title": "Verilog: 刷新文件树",
                "icon": "$(refresh)"
            },
            {
                "command": "verilogFormatter.setTopModule",
                "title": "Verilog: 设置顶层模块",
                "icon": "$(star)"
            },
            {
                "command": "verilogFormatter.rebuildIndex",
                "title": "Verilog: 重建符号索引"
            },
            {
                "command": "verilogFormatter.ucfToXdc",
                "title": "Verilog: UCF 转 XDC"
            },
            {
                "command": "verilogFormatter.incrementNumbers",
                "title": "Verilog: 数字递增 (+step)"
            },
            {
                "command": "verilogFormatter.decrementNumbers",
                "title": "Verilog: 数字递减 (-step)"
            }
        ],
        "keybindings": [
            {
                "command": "editor.action.formatDocument",
                "key": "ctrl+alt+f",
                "when": "editorTextFocus && editorLangId =~ /verilog|systemverilog/"
            },
            {
                "command": "verilogFormatter.instantiate",
                "key": "ctrl+alt+i",
                "when": "editorTextFocus && editorLangId =~ /verilog|systemverilog/"
            },
            {
                "command": "verilogFormatter.incrementNumbers",
                "key": "ctrl+alt+up",
                "when": "editorTextFocus"
            },
            {
                "command": "verilogFormatter.decrementNumbers",
                "key": "ctrl+alt+down",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "Verilog Formatter",
            "properties": {
                "verilogFormatter.indentSize": {
                    "type": "number",
                    "default": 2,
                    "description": "缩进空格数（Verilog 风格规范：2 空格）"
                },
                "verilogFormatter.alignPortComment": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否对齐端口行尾注释"
                },
                "verilogFormatter.newlineBeforeBegin": {
                    "type": "boolean",
                    "default": true,
                    "description": "begin 是否另起一行"
                },
                "verilogFormatter.hoverEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否启用悬停查看定义"
                },
                "verilogFormatter.lintEnabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "是否启用 xvlog 语法检查（需要配置 xvlog 环境变量）"
                },
                "verilogFormatter.lintSeverity": {
                    "type": "string",
                    "enum": [
                        "error",
                        "warning",
                        "info"
                    ],
                    "default": "warning",
                    "description": "语法检查最低报告级别"
                },
                "verilogFormatter.excludeFolders": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "ip",
                        "core",
                        "ipshared",
                        ".git"
                    ],
                    "description": "文件树和符号索引排除的文件夹名称"
                },
                "verilogFormatter.incrementStep": {
                    "type": "number",
                    "default": 1,
                    "description": "数字递增/递减的步长"
                },
                "verilogFormatter.formatOnSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "保存时自动格式化 Verilog/SystemVerilog 文件"
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "test": "jest",
        "package": "vsce package",
        "vscode:prepublish": "npm run compile"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/test/**/*.test.ts"
        ]
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/jest": "^29.0.0",
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.80.0",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "glob": "^10.5.0"
    }
}
